<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mindshare.auth.audit.LoginLogMapper">

    <insert id="insert" parameterType="com.mindshare.auth.audit.LoginLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO login_logs (
            user_id,
            identifier,
            channel,
            ip,
            user_agent,
            result,
            create_time
        ) VALUES (
            #{userId},
            #{identifier},
            #{channel},
            #{ip},
            #{userAgent},
            #{result},
            #{createTime}
        )
    </insert>
</mapper>
